{
  "name": "owflow",
  "version": "0.1.2",
  "description": "Spec-driven development AI workflow for OpenCode",
  "type": "module",
  "module": "index.ts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc && npm run copy-markdowns",
    "copy-markdowns": "cpy 'src/skills/**' dist/skills && cpy 'src/agents/**' dist/agents && cpy 'src/commands/**' dist/commands",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "workflow",
    "spec-driven",
    "development"
  ],
  "author": {
    "name": "Dawid Paluchowski",
    "email": "palucdev@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.14.44",
    "@types/bun": "^1.3.13",
    "cpy-cli": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "node": "^25"
  }
}
